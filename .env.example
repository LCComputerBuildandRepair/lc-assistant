# Copy to .env for local dev, and set these in Netlify → Environment variables for production.

# Database — Neon Postgres (use the POOLED connection string). Required.
DATABASE_URL="postgresql://user:pass@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Dashboard login + session
OWNER_PASSWORD="choose-a-password"
SESSION_SECRET="run: node -e \"console.log(require('crypto').randomBytes(24).toString('hex'))\""

# AI (assistant, chat, quotes, email triage) — any OpenAI-compatible provider.
# FREE default: Groq (https://console.groq.com — free key, no credit card).
AI_API_KEY="gsk_..."                              # your provider key
AI_BASE_URL="https://api.groq.com/openai/v1"      # Groq (free). See lib/ai.ts for others.
AI_MODEL="llama-3.3-70b-versatile"                # a capable free Groq model
# To switch to Claude later, set:
#   AI_BASE_URL=https://api.anthropic.com/v1/  AI_MODEL=claude-opus-4-8  AI_API_KEY=<anthropic key>

# Notifications
OWNER_EMAIL="lukepennywitt@yahoo.com"
OWNER_PHONE="+1419..."
RESEND_API_KEY=""
NOTIFY_FROM_EMAIL="alerts@lccomputerbuildandrepair.com"
SMS_PROVIDER="twilio"          # twilio | carrier | none
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER="+1..."

# Email inbox (IMAP + SMTP app password) — Yahoo or Gmail
MAIL_PROVIDER="yahoo"
MAIL_USER="lukepennywitt@yahoo.com"
MAIL_APP_PASSWORD=""
EMAIL_TRIAGE_MAX="5"           # emails AI-triaged per "Check mail" (serverless time limit)

# Contact/booking CORS + reminders cron secret
ALLOWED_ORIGIN="*"
CRON_SECRET="a-long-random-string"

# Quote tuning (optional)
QUOTE_TAX_RATE="0.07"
QUOTE_PARTS_MARKUP="0.10"
QUOTE_BUILD_LABOR="175"
QUOTE_REPAIR_LABOR="50"
